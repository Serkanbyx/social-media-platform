# ---- Server environment (placeholders only — never commit real .env) ----

# Runtime
NODE_ENV=development
PORT=5000

# Database
MONGO_URI=

# Auth (JWT_SECRET must be >= 32 chars in production)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS / client origin
CLIENT_URL=http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin seed
ADMIN_EMAIL=
ADMIN_USERNAME=
ADMIN_PASSWORD=
